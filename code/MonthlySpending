
import pandas as pd

# Load the dataset
df = pd.read_csv("/Users/kaitlynforister/Downloads/Personal_Finance_Dataset.csv")

# Convert Date column to datetime
df["Date"] = pd.to_datetime(df["Date"])

# Keep only Expenses (since you want spending)
df = df[df["Type"] == "Expense"]

# Create a Month column (YYYY-MM format)
df["Month"] = df["Date"].dt.to_period("M")

# Group by Month and Category and sum spending
monthly_spending = (
    df.groupby(["Month", "Category"])["Amount"]
    .sum()
    .reset_index()
)

# Convert Month to string for cleaner display
monthly_spending["Month"] = monthly_spending["Month"].astype(str)

# Print the table
print(monthly_spending)
# Create a pivot table (clean table format)
pivot_table = monthly_spending.pivot(
    index="Month",
    columns="Category",
    values="Amount"
).fillna(0)

# Save to CSV file
pivot_table.to_csv("/Users/kaitlynforister/Downloads/monthly_spending_table.csv")
